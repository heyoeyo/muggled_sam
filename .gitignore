# Model weights
*.pt
*.pth
*.onnx

# Selection history file
.history

# Cache files
*.pyc
__pycache__

# Common environment names
venv/
.venv/
env/
.env/

# Catch-all for local ignorables
ignore/
saved_images/
saved_train_weights/

# Allow file hiding using underscore prefix (useful for making custom script variants)
simple_examples/_*
experiments/_*
training/_*

# Ignore training config data
training/config/
training/*.json
training/*.txt
